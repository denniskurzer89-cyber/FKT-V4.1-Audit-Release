"base_uri":"https://localhost:8080/","height":356},"id":"aaf37a75","executionInfo":{"status":"error","timestamp":1764837051365,"user_tz":-60,"elapsed":123,"user":{"displayName":"Dennis Kurzer","userId":"17958925555354651978"}},"outputId":"23eb8756-fda1-4f68-c69c-60b0cebee851"},"source":["# Instanziieren der Klasse\n","fkt_constraint = FKTPrecisionConstraint()\n","fkt_constraint.initialize()\n","\n","# Beispielwerte für die kosmologischen Parameter (log10-skaliert)\n","example_log10_xi = -2.0  # Entspricht xi = 10^-2 = 0.01\n","example_log10_gb_Jm3 = -10.0 # Entspricht gb = 10^-10 J/m^3\n","\n","# Berechnung der Log-Likelihood\n","logL = fkt_constraint.log_likelihood(log10_xi=example_log10_xi, log10_gb_Jm3=example_log10_gb_Jm3)\n","\n","print(f\"Log-Likelihood für log10_xi = {example_log10_xi} und log10_gb_Jm3 = {example_log10_gb_Jm3}: {logL:.4f}\")\n","\n","# Sie können auch die erwartete BE-Verschiebung separat berechnen\n","expected_be_shift = fkt_constraint.compute_fkt_shift(log10_xi=example_log10_xi, log10_gb_Jm3=example_log10_gb_Jm3)\n","print(f\"Erwarteter Bindungsenergie-Shift für diese Parameter: {expected_be_shift:.4f} MeV\")"],"execution_count":8,"outputs":[{"output_type":"error","ename":"AttributeError","evalue":"'FKTPrecisionConstraint' object has no attribute 'log_info'","traceback":["\u001b[0;31m---------------------------------------------------------------------------\u001b[0m","\u001b[0;31mAttributeError\u001b[0m                            Traceback (most recent call last)","\u001b[0;32m/tmp/ipython-input-1163091936.py\u001b[0m in \u001b[0;36m<cell line: 0>\u001b[0;34m()\u001b[0m\n\u001b[1;32m      1\u001b[0m \u001b[0;31m# Instanziieren der Klasse\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0;32m----> 2\u001b[0;31m \u001b[0mfkt_constraint\u001b[0m \u001b[0;34m=\u001b[0m \u001b[0mFKTPrecisionConstraint\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0m\u001b[1;32m