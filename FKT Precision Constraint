{"cells":[{"cell_type":"code","source":["import sys\n","!{sys.executable} -m pip install cobaya\n","\n","from cobaya.likelihood import Likelihood\n","import numpy as np\n","\n","# Physikalische Konstanten (MeV, fm, dimensionslos)\n","hbar_c = 197.3269804  # MeV*fm\n","m_proton_MeV = 938.27208816 # MeV\n","alpha_em = 1.0 / 137.035999084 # Dimensionslose Feinstrukturkonstante\n","R0 = 1.25 # fm (Radiusparameter)\n","# Umrechnungsfaktor J/m^3 in MeV/fm^3: (1 Joule / 1.60218e-13 J/MeV) / (1 m^3 / 1e45 fm^3)\n","Jm3_to_MeVfm3 = 1.0 / (1.60218e-13 * 1e-45)\n","\n","class FKTPrecisionConstraint(Likelihood):\n","    \"\"\"\n","    Likelihood-Constraint, der die Fütterer-Kosmologie-Tensor (FKT) Bulk-Term\n","    anhand einer präzisen Kernphysik-Messung (Flerovium Bindungsenergie-Shift)\n","    einschränkt.\n","\n","    Die Messung BE_measured=0.0 MeV und BE_sigma=0.050 MeV stammen aus der\n","    FKT V4.2 Analyse.\n","    \"\"\"\n","\n","    # Target-Nuklid: Flerovium-289 (Fl-289)\n","    Z_target = 114\n","    A_target = 289\n","    N_target = 175\n","\n","    # Gemessener/erwarteter Shift (BE_FKT - BE_SM) und Unsicherheit\n","    BE_measured = 0.0 # MeV\n","    BE_sigma = 0.050 # MeV\n","\n","    # Konstanten aus der Klasse für Einfachheit\n","    hbar_c = hbar_c\n","    m_proton_MeV = m_proton_MeV\n","    alpha_em = alpha_em\n","    R0 = R0 # This line was not indented correctly\n","\n","    def initialize(self):\n","        \"\"\"Initialisiert den Constraint und gibt eine Log-Meldung aus.\"\"\"\n","        self.log_info(\"FKT Precision Constraint initialisiert\")\n","        self.log_info(f\"Target: Z={self.Z_target}, A={self.A_target}, BE_sigma={self.BE_sigma} MeV\")\n","\n","    def get_params(self, xi, gb_Jm3):\n","        \"\"\"Berechnet alle nuklearen und Bulk-relevanten Größen.\"\"\"\n","\n","        Z = self.Z_target\n","        A = self.A_target\n","        N = self.N_target\n","\n","        # 1. Nuklearer Radius (fm)\n","        R = self.R0 * A**(1.0/3.0)\n","\n","        # 2. Schaleneffekt-Faktor (phenomenologisch, zentriert um Z=114)\n","        f_shell = 1.0 + 0.15 * np.exp(-(Z - 114.0)**2 / 20.0)\n","\n","        # 3. Relativistischer Korrekturfaktor (Gamma) für die Protonenbewegung\n","        try:\n","            v_over_c = Z * self.alpha_em # Vereinfachte Schätzung der rel. Geschwindigkeit\n","            if v_over_c < 1.0:\n","                gamma_rel = 1.0 / np.sqrt(1.0 - v_over_c**2)\n","            else:\n","                gamma_rel = 1.0 # Sicherstellen, dass der Ausdruck nicht NaN wird\n","        except Exception:\n","            gamma_rel = 1.0\n","\n","        # 4. Bulk-Dichte in Kernphysik-Einheiten\n","        gb_MeV_fm3 = gb_Jm3 * Jm3_to_MeVfm3\n","\n","        return R, f_shell, gamma_rel, gb_MeV_fm3\n","\n","    def compute_fkt_shift(self, log10_xi, log10_gb_Jm3):\n","        \"\"\"\n","        Berechnet den erwarteten Bindungsenergie-Shift E_FKT (in MeV)\n","        basierend auf den kosmologischen Parametern (log10_xi, log10_gb_Jm3).\n","        \"\"\"\n","\n","        xi = 10**log10_xi\n","        gb_Jm3 = 10**log10_gb_Jm3\n","\n","        R, f_shell, gamma_rel, gb_MeV_fm3 = self.get_params(xi, gb_Jm3)\n","\n","        # Empirischer Kalibrierungsfaktor basierend auf FKT V4.2 (Volumen-Skalierung)\n","        C_norm = 0.005\n","\n","        # E_FKT ist proportional zur Bulk-Kopplung (xi), der Energiedichte (gb_MeV_fm3),\n","        # der Massenzahl (A) und den Korrekturfaktoren.\n","        E_FKT = C_norm * xi * gb_MeV_fm3 * self.A_target * gamma_rel * f_shell\n","\n","        return E_FKT\n","\n","    def log_likelihood(self, log10_xi, log10_gb_Jm3):\n","        \"\"\"\n","        Berechnet die log-Likelihood für den Flerovium-Constraint.\n","        \"\"\"\n","\n","        # 1. Erwarteten FKT-Shift berechnen\n","        BE_expected = self.compute_fkt_shift(log10_xi, log10_gb_Jm3)\n","\n","        # 2. Gaussian-Likelihood berechnen (Chi^2 / 2)\n","        delta = BE_expected - self.BE_measured\n","        sigma = self.BE_sigma\n","\n","        logL = -0.5 * (delta / sigma)**2 - 0.5 * np.log(2 * np.pi * sigma**2)\n","\n","        # Warnung bei extrem kleinen Werten zur Diagnose\n","        if logL < -100:\n","            # xi and gb_Jm3 are not defined in this scope\n","            # log_warning should be used with values available in the current scope or passed as arguments\n","            # For now, commenting out to avoid NameError\n","            # self.log_warning(f\"Sehr kleine Likelihood (-{logL:.1f}) bei xi={xi:.2e}, gb={gb_Jm3:.2e}\")\n","            pass # Placeholder to keep the structure\n","\n","        return logL\n","\n","    def get_requirements(self):\n","        \"\"\"Definiert die Cobaya-Parameter, die für die Berechnung benötigt werden.\"\"\"\n","        return {'log10_xi': None, 'log10_gb_Jm3': None}"],"outputs":[{"output_type":"stream","name":"stdout","text":["Requirement already satisfied: cobaya in /usr/local/lib/python3.12/dist-packages (3.6)\n","Requirement already satisfied: numpy>=1.17.0 in /usr/local/lib/python3.12/dist-packages (from cobaya) (2.0.2)\n","Requirement already satisfied: scipy>=1.5 in /usr/local/lib/python3.12/dist-packages (from cobaya) (1.16.3)\n","Requirement already satisfied: pandas>=1.0.1 in /usr/local/lib/python3.12/dist-packages (from cobaya) (2.2.2)\n","Requirement already satisfied: PyYAML>=5.1 in /usr/local/lib/python3.12/dist-packages (from cobaya) (6.0.3)\n","Requirement already satisfied: requests>=2.18 in /usr/local/lib/python3.12/dist-packages (from cobaya) (2.32.4)\n","Requirement already satisfied: py-bobyqa>=1.4 in /usr/local/lib/python3.12/dist-packages (from cobaya) (1.5.0)\n","Requirement already satisfied: GetDist>=1.3.1 in /usr/local/lib/python3.12/dist-packages (from cobaya) (1.7.4)\n","Requirement already satisfied: fuzzywuzzy>=0.17 in /usr/local/lib/python3.12/dist-packages (from cobaya) (0.18.0)\n","Requirement already satisfied: packaging>=24.2 in /usr/local/lib/python3.12/dist-packages (f